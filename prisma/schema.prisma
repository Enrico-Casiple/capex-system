// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

generator pothos {
  provider          = "prisma-pothos-types"
  clientOutput      = "../../generated/prisma/client"
  output            = "../lib/pothos/pothos-prisma-types.ts"
  documentation     = true
  prismaUtils       = true
  generateDatamodel = true
}

generator zod {
  provider = "npx zod-prisma-types"
  output   = "../generated/zod/prisma-zod-types"

  useMultipleFiles          = false
  writeBarrelFiles          = false
  createInputTypes          = true // DISABLE - don't create regular input types
  createModelTypes          = true // DISABLE - don't create model types
  addInputTypeValidation    = true
  addIncludeType            = false
  addSelectType             = false
  validateWhereUniqueInput  = false
  createUncheckedInputTypes = true // ENABLE - create only unchecked input types
  createRelationValuesTypes = true // DISABLE
  createPartialTypes        = false
  useDefaultValidators      = false
  coerceDate                = true
  writeNullishInModelTypes  = false
  useNoIntermediateModels   = false
  prismaClientPath          = "../../prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                       String            @id @default(auto()) @map("_id") @db.ObjectId
  name                     String?
  email                    String?           @unique
  password                 String?
  userName                 String?           @unique
  emailVerified            DateTime?
  image                    String?
  basicInformations        BasicInformation?
  isTwoFactorAuthEnabled   Boolean?          @default(false)
  otpCode                  String?
  auditLogs                AuditLog[]
  actions                  AuditLog[]        @relation("UserAsActor")
  userRoles                UserRole[]
  userAssignedBy           UserRole[]        @relation("UserAsRoleAssigner")
  emailOtpExpiresAt        DateTime? // OTP expiration time
  incrementalLoginAttempts Int?              @default(0) // For rate limiting login attempts

  workFlowStepTemplate WorkFlowStepTemplate[] @relation("StepAssignedToUser")
  workFlowInstanceStep WorkFlowInstanceStep[] @relation("StepAssignedToUser")
  requester            Request[]              @relation("RequestRequester")
  budgetRequester      Budget[]               @relation("BudgetRequester")

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // ✅ Add indexes for common searches
  @@index([isActive]) // Filter active/inactive users
  @@index([createdAt]) // Sort by creation date
}

model BasicInformation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName  String?
  middleName String?
  lastName   String?
  suffix     String?
  fullName   String?
  birthDate  DateTime?
  gender     String?

  phoneNumber String?

  address  String?
  city     String?
  province String?
  country  String?

  userId           String?           @unique @db.ObjectId
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reportingManager WorkInformation[] @relation("Manager")
  workInformations WorkInformation[] @relation("Employee")
  auditLogs        AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // ✅ Add indexes
  @@index([fullName]) // Search by full name
  @@index([phoneNumber]) // Search by phone
  @@index([isActive]) // Filter active/inactive
}

model WorkInformation {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  employeeNumber String? @unique

  employeeId String?           @db.ObjectId
  employee   BasicInformation? @relation("Employee", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  groupOfCompanyId String?         @db.ObjectId
  groupOfCompany   GroupOfCompany? @relation(fields: [groupOfCompanyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  companyId        String?         @db.ObjectId
  company          Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  departmentId     String?         @db.ObjectId
  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  positionId       String?         @db.ObjectId
  position         Position?       @relation(fields: [positionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  jobLevelId       String?         @db.ObjectId
  jobLevel         JobLevel?       @relation(fields: [jobLevelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employmentTypeId String?         @db.ObjectId // Full-time, Part-time, Contract, Probationary
  employmentType   Type?           @relation("EmploymentType", fields: [employmentTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  employmentStatusId String? @db.ObjectId // Active, Resigned, Terminated, On Leave
  employmentStatus   Status? @relation("EmploymentStatus", fields: [employmentStatusId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  reportingManagerId String?           @db.ObjectId
  reportingManager   BasicInformation? @relation("Manager", fields: [reportingManagerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  hireDate                     DateTime? // The date the employee was hired
  regularizationDate           DateTime? // For probationary employees, the date they become regular employees but in 180 days period after hire date
  firstProbationEvaluationDate DateTime? // For probationary employees, the date of their first evaluation, typically 3rd month after hire
  finalProbationEvaluationDate DateTime? // For probationary employees, the date of their final evaluation, typically 5th month after hire
  contractEndDate              DateTime? // For contract employees, the date their contract ends
  seasonalEndDate              DateTime? // For seasonal employees, the date their season ends
  endDate                      DateTime? // For resigned employees, the date they resigned

  workLocationId  String?   @db.ObjectId // Onsite, Remote, Hybrid
  workLocation    Location? @relation("WorkLocation", fields: [workLocationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workSetupTypeId String?   @db.ObjectId // Onsite, Hybrid, Remote
  workSetupType   Type?     @relation("WorkSetupType", fields: [workSetupTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  shiftingSchedule ShiftingSchedule? @relation("ShiftingSchedule")
  auditLogs        AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // ✅ Add indexes
  @@index([employeeId]) // Lookup employee
  @@index([companyId]) // Filter by company
  @@index([departmentId]) // Filter by department
  @@index([employmentStatusId]) // Filter by employment status
  @@index([hireDate]) // Sort by hire date
  @@index([isActive]) // Filter active employees
  @@index([companyId, departmentId]) // Composite: company + department
}

model GroupOfCompany {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String?
  acronym          String?
  description      String? // Description of the group of company
  industryTypeId   String?           @db.ObjectId
  industryType     Type?             @relation("IndustryType", fields: [industryTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  headquartersId   String?           @db.ObjectId
  headquarters     Location?         @relation("GroupOfCompanyLocation", fields: [headquartersId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  companies        Company[]
  auditLogs        AuditLog[]
  workInformations WorkInformation[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([name, acronym]) // Ensure unique group of company names
  // ✅ Add indexes
  @@index([industryTypeId]) // Filter by industry
}

model Company {
  id                           String                  @id @default(auto()) @map("_id") @db.ObjectId
  name                         String?
  acronym                      String?
  description                  String? // Description of the company
  groupOfCompanyId             String?                 @db.ObjectId
  groupOfCompany               GroupOfCompany?         @relation(fields: [groupOfCompanyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  locationsid                  String?                 @db.ObjectId
  locations                    Location?               @relation("CompaniesLocation", fields: [locationsid], references: [id], onDelete: SetNull, onUpdate: Cascade)
  conctactNumber               String?
  email                        String?
  departments                  Department[]            @relation("CompanyDepartments")
  logo                         String?
  jobLevels                    JobLevel[]              @relation("CompanyJobLevels")
  auditLogs                    AuditLog[]
  workInformations             WorkInformation[]
  scopeTypeId                  String?                 @db.ObjectId
  scopeType                    Type?                   @relation("CompanyType", fields: [scopeTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  request                      Request[]
  budget                       Budget[]
  crfCompany                   CapitalRecoveryFactor[] @relation("CRFCompany")
  positionCompany              Position[]              @relation("PositionCompany")
  workFlowTemplateScopeCompany WorkFlowTemplateScope[] @relation("WorkFlowTemplateScopeCompany")
  isActive                     Boolean?                @default(true)
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  // ✅ Add indexes
  @@unique([name, acronym])
  @@index([groupOfCompanyId]) // Filter by group
}

model Department {
  id                              String                  @id @default(auto()) @map("_id") @db.ObjectId
  name                            String?
  acronym                         String?
  description                     String?
  companyId                       String?                 @db.ObjectId
  company                         Company?                @relation("CompanyDepartments", fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  auditLogs                       AuditLog[]
  workInformations                WorkInformation[]
  scopeTypeId                     String?                 @db.ObjectId
  scopeType                       Type?                   @relation("DepartmentType", fields: [scopeTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  request                         Request[]
  budget                          Budget[]
  requestResponsibilityCenter     Request[]               @relation("RequestResponsibilityCenter")
  crfDepartment                   CapitalRecoveryFactor[] @relation("CRFDepartment")
  workFlowTemplateScopeDepartment WorkFlowTemplateScope[] @relation("WorkFlowTemplateScopeDepartment")
  isActive                        Boolean?                @default(true)
  createdAt                       DateTime?               @default(now())
  updatedAt                       DateTime?               @updatedAt

  @@unique([name, acronym]) // Department names should be unique within a company
  // ✅ Add indexes
  @@index([companyId]) // Lookup by company
}

model Position {
  id                            String                  @id @default(auto()) @map("_id") @db.ObjectId
  name                          String?
  acronym                       String?
  description                   String?
  companyId                     String?                 @db.ObjectId
  company                       Company?                @relation("PositionCompany", fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  auditLogs                     AuditLog[]
  workInformations              WorkInformation[]
  isActive                      Boolean?                @default(true)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  scopeTypeId                   String?                 @db.ObjectId
  scopeType                     Type?                   @relation("PositionType", fields: [scopeTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowTemplateScopePosition WorkFlowTemplateScope[] @relation("WorkFlowTemplateScopePosition")

  // ✅ Add indexes
  @@unique([name, acronym]) // Ensure unique position names
}

model JobLevel {
  id                            String                  @id @default(auto()) @map("_id") @db.ObjectId
  name                          String?
  description                   String?
  acronym                       String?
  jobcodeTypeId                 String?                 @db.ObjectId
  jobcodeType                   Type?                   @relation("JobCodeType", fields: [jobcodeTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  companyId                     String?                 @db.ObjectId
  company                       Company?                @relation("CompanyJobLevels", fields: [companyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  WorkFlowTemplateScopeJobLevel WorkFlowTemplateScope[] @relation("WorkFlowTemplateScopeJobLevel")
  workInformations              WorkInformation[]
  auditLogs                     AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([name, acronym]) // Job level names should be unique within a company
  // ✅ Add indexes
  @@index([companyId]) // Lookup by company
}

model Location {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name                     String?
  description              String?
  workInformations         WorkInformation[] @relation("WorkLocation")
  groupOfCompaniesLocation GroupOfCompany[]  @relation("GroupOfCompanyLocation")
  companiesLocation        Company[]         @relation("CompaniesLocation")
  auditLogs                AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // ✅ Add indexes
  @@index([name]) // Search by name
}

model ShiftingSchedule {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String // "8-5", "Night Shift", "Flexible"
  description String

  startTime  DateTime // shift start time (time-of-day)
  endTime    DateTime // shift end time (time-of-day)
  lunchStart DateTime
  lunchEnd   DateTime
  breakStart DateTime
  breakEnd   DateTime

  workDays          Int[] // 0 = Sunday, 1 = Monday ... 6 = Saturday
  // example: [1,2,3,4,5] = Mon–Fri
  restDays          Int[] // optional, override default Sat/Sun
  workInformationId String?          @unique @db.ObjectId
  workInformation   WorkInformation? @relation("ShiftingSchedule", fields: [workInformationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  auditLogs         AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  date        DateTime
  isRecurring Boolean    @default(false)
  description String
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ Add indexes
  @@index([date]) // Search by date
  @@index([isRecurring]) // Filter recurring holidays
}

model Role {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  description String?

  // ERP additions
  roleType String? // "SYSTEM" | "CUSTOM" | "TEMPLATE"
  // SYSTEM = built-in like SAP standard roles, cannot be deleted
  // CUSTOM  = user created
  // TEMPLATE = used as base to clone from

  isDefault Boolean @default(false)
  // true = auto-assigned to new users (like NetSuite "Employee Center")

  parentRoleId String? @db.ObjectId
  parentRole   Role?   @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childRoles   Role[]  @relation("RoleHierarchy")
  // Role inheritance — child inherits parent permissions (like SAP role hierarchy)

  rolePermissions RolePermission[]
  userRoles       UserRole[]
  auditLogs       AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([name])
  @@index([roleType])
}

model Permission {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  description  String?
  module       String?
  resource     String?
  action       String?
  displayOrder Int?

  isGlobal    Boolean @default(false)
  isAdmin     Boolean @default(false)
  globalLimit Int? // ✅ max number of users that can have this permission — null means unlimited

  rolePermissions RolePermission[]
  auditLogs       AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([module, resource, action])
  @@index([name])
  @@index([module])
  @@index([resource, action])
}

model RolePermission {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String? @db.ObjectId
  permissionId String? @db.ObjectId

  scopeValues String[]
  conditions  Config[] @relation("PermissionScopeView")

  isActive Boolean? @default(true)

  role       Role?       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission? @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  auditLogs AuditLog[]
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@unique([roleId, permissionId, scopeValues])
  @@index([roleId])
  @@index([permissionId])
  @@index([scopeValues])
  @@index([isActive])
}

model UserRole {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId
  roleId String? @db.ObjectId

  scopeTypeId String?  @db.ObjectId
  scopeValues String[]

  // Override conditions per user assignment
  conditionOverrides Json?
  // Example: same Role "Manager" but this specific user
  // gets extra condition { "maxApprovalAmount": 50000 }

  assignedById   String? @db.ObjectId
  // who assigned this role — important for audit
  userAssignedBy User?   @relation("UserAsRoleAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  expiresAt DateTime?
  // temporary role assignment — auto-expires (like SAP time-based roles)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role? @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  auditLogs AuditLog[]
  isActive  Boolean    @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@unique([userId, roleId, scopeTypeId])
  @@index([userId])
  @@index([roleId])
  @@index([expiresAt])
}

model AuditLog {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  modelId      String?   @db.ObjectId // ID of the affected record
  modelName    String? // e.g. "User", "Company", etc.
  action       String? // e.g. "create", "update", "delete"
  actionTypeId String?   @db.ObjectId // "archived", "restored or created"
  actionType   Type?     @relation("ActionType", fields: [actionTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  timestamp    DateTime? @default(now())
  actorId      String?   @db.ObjectId // ID of the user who performed the action
  actor        User?     @relation("UserAsActor", fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  oldDetails   Json? // JSON string of the record before the change
  newDetails   Json? // JSON string of the record after the change

  holiday               Holiday?               @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  shiftSchedule         ShiftingSchedule?      @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  position              Position?              @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  jobLevel              JobLevel?              @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  type                  Type?                  @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status                Status?                @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  location              Location?              @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  user                  User?                  @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  basicInformation      BasicInformation?      @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workInformation       WorkInformation?       @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  groupOfCompany        GroupOfCompany?        @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  company               Company?               @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  department            Department?            @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userRole              UserRole?              @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rolePermission        RolePermission?        @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  permission            Permission?            @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  role                  Role?                  @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowTemplate      WorkFlowTemplate?      @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  configCondition       ConfigCondition?       @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  config                Config?                @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowStepTemplate  WorkFlowStepTemplate?  @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowInstance      WorkFlowInstance?      @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowInstanceStep  WorkFlowInstanceStep?  @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  signature             Signature?             @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowTemplateScope WorkFlowTemplateScope? @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  requestItem           RequestItem?           @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  budgetSnapshot        BudgetSnapshot?        @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  budgetLedger          BudgetLedger?          @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  budget                Budget?                @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  request               Request?               @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  category              Category?              @relation(fields: [modelId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  parentId              String?                @db.ObjectId // For hierarchical logs (e.g. a batch of changes)
  parent                AuditLog?              @relation("ParentLog", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  auditLogs             AuditLog[]             @relation("ParentLog")

  isActive        Boolean?       @default(true)
  createdAt       DateTime?      @default(now())
  updatedAt       DateTime?      @updatedAt
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String?        @db.ObjectId

  // Indexes for fast queries
  @@index([modelName, action]) // Find changes to specific models
  @@index([timestamp]) // Sort by time
  @@index([actorId]) // Find who made changes
  @@index([modelId]) // Find changes to specific record
  @@index([isActive]) // Filter active logs
}

model WorkFlowTemplate {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  description String?

  isGlobal Boolean? @default(false)

  version Int? @default(1)

  scope WorkFlowTemplateScope[]
  steps WorkFlowStepTemplate[]

  workFlowInstance WorkFlowInstance[]
  request          Request[]
  budget           Budget[]

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@index([name])
}

model WorkFlowTemplateScope {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  templateId String?           @db.ObjectId
  template   WorkFlowTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Who's this workflow template applicable to? (for auto-assigning templates based on user attributes)
  companyId    String?     @db.ObjectId
  company      Company?    @relation("WorkFlowTemplateScopeCompany", fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  departmentId String?     @db.ObjectId
  department   Department? @relation("WorkFlowTemplateScopeDepartment", fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  positionId   String?     @db.ObjectId
  position     Position?   @relation("WorkFlowTemplateScopePosition", fields: [positionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  jobLevelId   String?     @db.ObjectId
  jobLevel     JobLevel?   @relation("WorkFlowTemplateScopeJobLevel", fields: [jobLevelId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@index([templateId])
}

model WorkFlowStepTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  workflowTemplateId String?           @db.ObjectId
  workflowTemplate   WorkFlowTemplate? @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  stepNumber       Int?
  assignmentTypeId String? @db.ObjectId
  assignmentType   Type?   @relation("StepAssignmentType", fields: [assignmentTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // STATIC
  assignedToUserId String? @db.ObjectId
  assignedToUser   User?   @relation("StepAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // DYNAMIC
  assignmentRules Json?
  isHaveCondition Boolean? @default(false) // whether this step has conditions that determine if it should be included or skipped
  // CONDITIONS (skip or include step)
  conditions      Config[] @relation("StepConditions")

  // PARALLEL APPROVAL
  isParallel        Boolean? @default(false)
  requiredApprovals Int? // e.g. 2 out of 3 approvers

  // SLA + ESCALATION
  slaHours           Int?
  escalationRules    Json?
  // SECURITY + COMPLIANCE
  esignatureRequired Boolean? @default(false)
  attachmentRequired Boolean? @default(false)

  workFlowInstanceStep WorkFlowInstanceStep[]

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@unique([workflowTemplateId, stepNumber])
  @@index([workflowTemplateId])
}

model WorkFlowInstance {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  templateId String?           @db.ObjectId
  template   WorkFlowTemplate? @relation(fields: [templateId], references: [id])

  title       String? // e.g. "Expense Approval - John Doe"
  description String?

  statusId    String? @db.ObjectId
  status      Status? @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentStep Int?    @default(1)

  referenceTypeId String? @db.ObjectId // e.g. "ExpenseReport", "LeaveRequest", etc.
  referenceType   Type?   @relation("ReferenceType", fields: [referenceTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  steps      WorkFlowInstanceStep[]
  signatures Signature[]
  requestId  String?                @unique @db.ObjectId
  request    Request?               @relation(fields: [requestId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  budgetId   String?                @unique @db.ObjectId
  budget     Budget?                @relation(fields: [budgetId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt
  // @@index([referenceId])

  @@index([templateId])
  @@index([statusId])
}

model WorkFlowInstanceStep {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  instanceId String?           @db.ObjectId
  instance   WorkFlowInstance? @relation(fields: [instanceId], references: [id])

  stepTemplateId String?               @db.ObjectId
  stepTemplate   WorkFlowStepTemplate? @relation(fields: [stepTemplateId], references: [id])

  stepNumber Int?

  statusId String? @db.ObjectId
  status   Status? @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  assignedToUserId String?   @db.ObjectId
  assignedToUser   User?     @relation("StepAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  startedAt        DateTime? @default(now())
  actionAt         DateTime?

  comments   String?
  isEditable Boolean? @default(false)
  source     String? // e.g. "COPIED_FROM_TEMPLATE", "AUTO_RESOLVED_FROM_RULE", "email"

  isRequired Boolean?    @default(true)
  signature  Signature[]

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@index([instanceId])
  @@index([assignedToUserId])
}

model Signature {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  instanceId String?           @db.ObjectId
  instance   WorkFlowInstance? @relation(fields: [instanceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  stepId        String?               @db.ObjectId
  step          WorkFlowInstanceStep? @relation(fields: [stepId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  attachmentUrl String?

  userId String? @db.ObjectId

  signatureHash String? // cryptographic hash
  payload       Json? // what was signed

  ipAddress String?
  userAgent String?

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@index([instanceId])
  @@index([userId])
}

// =================================================================================================
//                                 CONFIG MODELS
// =================================================================================================

model Type {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name           String?
  description    String?
  modelNameType  String?
  employmentType WorkInformation[] @relation("EmploymentType")
  workSetupType  WorkInformation[] @relation("WorkSetupType")
  industryType   GroupOfCompany[]  @relation("IndustryType")
  companies      Company[]         @relation("CompanyType")
  departments    Department[]      @relation("DepartmentType")
  jobPositions   Position[]        @relation("PositionType")
  jobLevels      JobLevel[]        @relation("JobCodeType")
  actionType     AuditLog[]        @relation("ActionType")
  auditLogs      AuditLog[]

  stepAssignmentType WorkFlowStepTemplate[] @relation("StepAssignmentType")
  workFlowInstance   WorkFlowInstance[]     @relation("ReferenceType")
  budgetMovementType BudgetLedger[]         @relation("BudgetMovementType")
  sourceDocumentType BudgetLedger[]         @relation("SourceDocumentType")

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // ✅ Add indexes
  @@unique([name, modelNameType])
  @@index([modelNameType]) // Filter by type
  @@index([name]) // Search by name
}

model Category {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  description   String?
  acronym       String?
  modelNameType String?

  budget              Budget[]
  crfCategory         CapitalRecoveryFactor[] @relation("CRFCategory")
  requestItemCategory RequestItem[]           @relation("RequestItemCategory")
  auditLogs           AuditLog[]

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([name, acronym, modelNameType])
  @@index([name])
}

model ConfigCondition {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  configId String? @db.ObjectId
  config   Config? @relation("Config", fields: [configId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // RULE or GROUP
  nodeType String? // "RULE" | "GROUP"

  // GROUP only
  logicalOperator String? // "AND" | "OR" | "XOR" | "NOT"

  // RULE only
  field    String?
  operator String? // GT, EQ, IN, etc.
  value    Json?

  // TREE STRUCTURE
  parentConditionId String?           @db.ObjectId
  parentCondition   ConfigCondition?  @relation("ConditionTree", fields: [parentConditionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subConditions     ConfigCondition[] @relation("ConditionTree")
  auditLogs         AuditLog[]
  isActive          Boolean?          @default(true)
  createdAt         DateTime?         @default(now())
  updatedAt         DateTime?         @updatedAt

  @@index([configId])
  @@index([parentConditionId])
}

model Config {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  modelName            String? // e.g. "User", "Company", etc. "Role"
  group                String // e.g. "ApproverStatus", "ConditionOperator", "ApproverType" "RolePermissionScope"
  codeKey              String? // e.g. "maxLoginAttempts", "passwordPolicy", etc "scopeValues", "conditionOperator", "approverType"
  code                 String? // e.g. "MAX_LOGIN_ATTEMPTS", "PASSWORD_POLICY", etc. for easy reference in code "SCOPE_VALUES", "CONDITION_OPERATOR", "APPROVER_TYPE"
  codeLabel            String? // e.g. "Max Login Attempts", "Password Policy", etc. for display in admin UI "Scope Values", "Condition Operator", "Approver Type"
  value                Json? // JSON string of the config value, can be any type (string, number, boolean, object, array) "["VALUE1", "VALUE2"]", "{ "operator": ">", "value": 10000 }", etc.
  conditions           ConfigCondition[]     @relation("Config")
  modelId              String?               @db.ObjectId // ID of the related record, null if it's a global config not tied to a specific record
  rolePermission       RolePermission?       @relation("PermissionScopeView", fields: [modelId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  workFlowStepTemplate WorkFlowStepTemplate? @relation("StepConditions", fields: [modelId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  sortOrder Int?
  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt

  @@index([modelName, modelId])
  @@index([group, codeKey])
}

model Status {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name                  String?
  modelNameType         String?
  workInformations      WorkInformation[]       @relation("EmploymentStatus")
  workFlowInstanceSteps WorkFlowInstanceStep[]
  workFlowInstances     WorkFlowInstance[]
  request               Request[]
  requestItems          RequestItem[]
  auditLogs             AuditLog[]
  budget                Budget[]                @relation("BudgetStatus")
  crfStatus             CapitalRecoveryFactor[] @relation("CRFStatus")

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([name, modelNameType])
  // ✅ Add indexes
  @@index([modelNameType]) // Filter by type
  @@index([name]) // Search by name
}

//

model Request {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title         String?
  description   String?
  requestNumber String? @unique // "REQ-2025-00001"

  requesterId            String?     @db.ObjectId
  requester              User?       @relation("RequestRequester", fields: [requesterId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  companyId              String?     @db.ObjectId
  company                Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  departmentId           String?     @db.ObjectId
  department             Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  dateNeeded             DateTime?
  responsibilityCenterId String?     @db.ObjectId
  responsibilityCenter   Department? @relation("RequestResponsibilityCenter", fields: [responsibilityCenterId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Request a budget If not have a Budget Id yet
  requestedCRF    CapitalRecoveryFactor? // For requesting a budget when creating a request, if the request is directly linked to an existing budget then this will be null and the budgetId field in Request will be used instead
  requestItems    RequestItem[]
  quotationUrl    String?
  quotationAmount Float?
  currency        String?                @default("PHP")

  workflowTemplateId String?           @db.ObjectId
  workflowTemplate   WorkFlowTemplate? @relation(fields: [workflowTemplateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workFlowInstance   WorkFlowInstance? // For approval workflow

  approvedAt DateTime?
  statusId   String?    @db.ObjectId
  status     Status?    @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  auditLogs  AuditLog[]
  isActive   Boolean?   @default(true)
  createdAt  DateTime?  @default(now())
  updatedAt  DateTime?  @updatedAt
}

// Budget <= => Request -> Many to Many Relationship
model CapitalRecoveryFactor {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name           String?
  description    String?
  crfReferenceNo String? // "CRF-2025-00001"

  statusId          String?     @db.ObjectId
  status            Status?     @relation("CRFStatus", fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  companyId         String?     @db.ObjectId
  company           Company?    @relation("CRFCompany", fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  departmentId      String?     @db.ObjectId
  department        Department? @relation("CRFDepartment", fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  categoryId        String?     @db.ObjectId
  category          Category?   @relation("CRFCategory", fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  utilizedBudget    Float? // percentage of the budget that this request will consume, e.g. 0.25 means 25% of the budget
  approvedAmount    Float? // the amount that was approved for this request, used for reporting and forecasting
  requestedAmount   Float? // the actual amount that this request is asking for, used for approval and reporting
  newBalanceAmmount Float? // computed as approvedAmount - sum of committed and actual amounts from BudgetLedger, used for reporting and forecasting
  projectedBudget   Float? // the projected budget amount that this request is asking for, used for forecasting and reporting
  remark            Json? // Provided Specs During AOP and Provied purpose During AOP

  requestId String?  @unique @db.ObjectId
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  budgetId  String?  @db.ObjectId
  budget    Budget?  @relation(fields: [budgetId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([crfReferenceNo])
}

model Budget {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  crf CapitalRecoveryFactor[]

  fiscalYear   String? // Date Range June 1,  - May 31 // No Year since this are recurring every year,
  statusId     String? @db.ObjectId // DRAFT | FOR_APPROVAL | APPROVED | REJECTED | CLOSED | VERIFIED
  statusBudget Status? @relation("BudgetStatus", fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  budgetRefNo  String? @unique // "2025(AB - Approved, AX- Not Approved)-(Company)-00001"

  companyId    String?     @db.ObjectId
  company      Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  departmentId String?     @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  categoryId   String?     @db.ObjectId
  category     Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  requesterId  String?     @db.ObjectId
  requester    User?       @relation("BudgetRequester", fields: [requesterId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  purpose  String?
  specs    String?
  quantity Int?
  remark   Json? // Provided Specs During AOP and Provied purpose During AOP

  workflowTemplateId String?           @db.ObjectId
  workflowTemplate   WorkFlowTemplate? @relation(fields: [workflowTemplateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workflowInstance   WorkFlowInstance?

  submittedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?

  requestedAmount Float?
  approvedAmount  Float?
  remainingAmount Float? // computed as approvedAmount - sum of committed and actual amounts from BudgetLedger
  currency        String? @default("PHP")

  budgetLedgers  BudgetLedger[]
  budgetSnapshot BudgetSnapshot[]

  isFrozen     Boolean?   @default(false)
  freezeReason String?
  frozenAt     DateTime?
  auditLogs    AuditLog[]
  isActive     Boolean?   @default(true)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([companyId])
  @@index([departmentId])
  @@index([fiscalYear])
  @@index([workflowTemplateId])
}

model BudgetLedger {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // =========================================
  // RELATION
  // =========================================

  budgetId String? @db.ObjectId
  budget   Budget? @relation(fields: [budgetId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // =========================================
  // MOVEMENT TYPE (SAP POSTING TYPES)
  // =========================================

  typeId String? @db.ObjectId
  type   Type?   @relation("BudgetMovementType", fields: [typeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // Examples of movement types:
  // COMMITMENT   (PO created)
  // ACTUAL       (invoice paid)
  // RESERVATION  (pre-check)
  // RELEASE      (cancellation)
  // ADJUSTMENT   (manual correction)

  amount   Float
  currency String? @default("PHP")

  // =========================================
  // SOURCE DOCUMENT (NETSUITE STYLE)
  // =========================================

  sourceTypeId String? @db.ObjectId
  sourceType   Type?   @relation("SourceDocumentType", fields: [sourceTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // Examples of source document types:
  // PURCHASE_REQUEST | PURCHASE_ORDER | INVOICE | JOURNAL | MANUAL

  sourceId    String?
  referenceNo String?
  remark      String?
  auditLogs   AuditLog[]
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([budgetId])
  @@index([typeId])
  @@index([sourceTypeId])
}

model BudgetSnapshot {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  budgetId String? @db.ObjectId
  budget   Budget? @relation(fields: [budgetId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  approvedAmount  Float?
  committedAmount Float? @default(0)
  actualAmount    Float? @default(0)

  availableAmount Float? // computed snapshot
  currency        String? @default("PHP")

  auditLogs AuditLog[]
  isActive  Boolean?   @default(true)
  createdAt DateTime?  @default(now())
  updatedAt DateTime?  @updatedAt
}

model RequestItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  requestId   String?  @db.ObjectId
  request     Request? @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  statusId    String?  @db.ObjectId
  status      Status?  @relation(fields: [statusId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  isPriceNeed Boolean? @default(false)

  itemId           String?        @db.ObjectId // optional link to inventory item
  inventoryItem    InventoryItem? @relation(fields: [itemId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  categoryId       String?        @db.ObjectId
  category         Category?      @relation("RequestItemCategory", fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  description      String?
  quantity         Int?
  unitOfMeasure    String?
  vatPercentage    Float?
  isInclusiveVat   Boolean?       @default(false)
  unitPrice        Float?
  amountGrossOfVat Float? // computed as quantity * unitPrice
  totalPrice       Float?
  attachmentUrl    String?
  auditLogs        AuditLog[]
  isActive         Boolean?       @default(true)
  createdAt        DateTime?      @default(now())
  updatedAt        DateTime?      @updatedAt

  @@index([requestId])
}

// Inventory Item Model
model InventoryItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name        String?
  description String?

  companyId       String? @db.ObjectId
  departmentId    String? @db.ObjectId
  categoryId      String? @db.ObjectId
  quantityInStock Int?
  unitOfMeasure   String?
  remainingStock  Int? // computed as quantityInStock - sum of quantities from RequestItems that are linked to this inventory item

  requestItems RequestItem[]
  auditLogs    AuditLog[]
  isActive     Boolean?      @default(true)
  createdAt    DateTime?     @default(now())
  updatedAt    DateTime?     @updatedAt

  @@index([name])
}
