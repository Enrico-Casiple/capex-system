{
  "name": "opex-capex-request-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"DEV\" --prefix \"[{name}]\" --prefix-colors \"blue\" \"npm run memcached:install\" \"NODE_ENV=development tsx watch lib/server/server.ts\"",
    "server": "concurrently --names \"CODEGEN,GQL,DEV,STUDIO\" --prefix \"[{name}]\" --prefix-colors \"blue,cyan,green,yellow\" \"npm run codegen:watch\" \"npm run generate:gql\" \"npm run dev\" \"npm run prisma:studio\"",
    "generate:gql": "tsx lib/scripts/generateGQLFiles.ts",
    "generate:gql:force": "tsx lib/scripts/generateGQLFiles.ts --force",
    "codegen:gen": "npx prisma generate && npx prisma db push && graphql-codegen --config lib/pothos/codegen.ts",
    "codegen:watch": "npx prisma generate && graphql-codegen --config lib/pothos/codegen.ts --watch",
    "clean:types": "rm -rf lib/generated",
    "build": "next build",
    "build:start": "NODE_ENV=development  tsx lib/server/server.ts",
    "deploy": "npm run generate:gql && npm run build && npm run build:start",
    "lint": "next lint --fix",
    "lint:check": "next lint",
    "type-check": "tsc --noEmit --incremental",
    "type-check:watch": "tsc --noEmit --incremental --watch",
    "clean:next": "rm -rf .next node_modules/.cache",
    "clean:all": "rm -rf .next node_modules package-lock.json",
    "clean": "npm run clean:next && npm run clean:all",
    "prebuild:strict": "npm run type-check && npm run lint:check",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma generate && prisma db push --force-reset && prisma format && npm run codegen:gen && npm run prebuild:strict",
    "memcached:install": "sudo dnf install memcached -y && sudo systemctl start memcached && sudo systemctl enable memcached",
    "setup:memcached": "chmod +x lib/scripts/setup.sh && bash lib/scripts/setup.sh"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@graphql-yoga/render-apollo-sandbox": "^0.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.2",
    "@prisma/client": "^6.19.2",
    "@prisma/extension-accelerate": "^3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns-tz": "^3.2.0",
    "express": "^4.18.2",
    "graphql": "^16.13.1",
    "graphql-scalars": "^1.25.0",
    "graphql-ws": "^5.16.2",
    "graphql-yoga": "^5.18.1",
    "jose": "^6.2.0",
    "jwt-decode": "^4.0.0",
    "memcached": "^2.2.2",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^9.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.1",
    "shadcn-ui": "^0.9.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate": "^1.0.3",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/client-preset": "^5.2.3",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-resolvers": "^5.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/memcached": "^2.2.10",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "zod-prisma-types": "^3.3.11"
  }
}
